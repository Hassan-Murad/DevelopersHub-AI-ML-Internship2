   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Streamlit App\n",
    "\n",
    "The Streamlit interface is in `app.py`. Run it with:\n",
    "```bash\n",
    "streamlit run app.py\n",
    "```"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Write the Streamlit app to disk\n",
    "APP_CODE = '''\n",
    "import streamlit as st\n",
    "import os\n",
    "from langchain_community.vectorstores import FAISS\n",
    "from langchain_community.embeddings import HuggingFaceEmbeddings\n",
    "from langchain.memory import ConversationBufferMemory\n",
    "from langchain.chains import ConversationalRetrievalChain\n",
    "from langchain_openai import ChatOpenAI\n",
    "\n",
    "st.set_page_config(page_title=\"📚 RAG Chatbot\", page_icon=\"🤖\", layout=\"wide\")\n",
    "st.title(\"📚 Context-Aware RAG Chatbot\")\n",
    "st.markdown(\"Ask anything about the knowledge base. The bot remembers your conversation history.\")\n",
    "\n",
    "@st.cache_resource\n",
    "def load_chain(api_key):\n",
    "    embeddings = HuggingFaceEmbeddings(model_name=\"all-MiniLM-L6-v2\")\n",
    "    vs = FAISS.load_local(\"faiss_index\", embeddings, allow_dangerous_deserialization=True)\n",
    "    llm = ChatOpenAI(model=\"gpt-3.5-turbo\", temperature=0.2, openai_api_key=api_key)\n",
    "    memory = ConversationBufferMemory(memory_key=\"chat_history\", return_messages=True, output_key=\"answer\")\n",
    "    return ConversationalRetrievalChain.from_llm(llm=llm, retriever=vs.as_retriever(search_kwargs={\"k\": 3}),\n",
    "                                                  memory=memory, return_source_documents=True)\n",
    "\n",
    "# Sidebar – API key\n",
    "with st.sidebar:\n",
    "    st.header(\"Configuration\")\n",
    "    api_key = st.text_input(\"OpenAI API Key\", type=\"password\",\n",
    "                             value=os.getenv(\"OPENAI_API_KEY\", \"\"))\n",
    "    st.markdown(\"---\")\n",
    "    st.markdown(\"**Knowledge Base:** ML Concepts\")\n",
    "\n",
    "if not api_key:\n",
    "    st.info(\"Please enter your OpenAI API key in the sidebar to start chatting.\")\n",
    "    st.stop()\n",
    "\n",
    "chain = load_chain(api_key)\n",
    "\n",
    "# Chat history\n",
    "if \"messages\" not in st.session_state:\n",
    "    st.session_state.messages = []\n",
    "\n",
    "for msg in st.session_state.messages:\n",
    "    with st.chat_message(msg[\"role\"]):\n",
    "        st.markdown(msg[\"content\"])\n",
    "\n",
    "if prompt := st.chat_input(\"Ask a question about machine learning…\"):\n",
    "    st.session_state.messages.append({\"role\": \"user\", \"content\": prompt})\n",
    "    with st.chat_message(\"user\"):\n",
    "        st.markdown(prompt)\n",
    "\n",
    "    with st.chat_message(\"assistant\"):\n",
    "        with st.spinner(\"Retrieving and generating…\"):\n",
    "            result = chain({\"question\": prompt})\n",
    "            answer = result[\"answer\"]\n",
    "            sources = [d.metadata.get(\"source\", \"Unknown\") for d in result[\"source_documents\"]]\n",
    "            st.markdown(answer)\n",
    "            with st.expander(\"📎 Sources\"):\n",
    "                for s in set(sources):\n",
    "                    st.markdown(f\"- `{s}`\")\n",
    "\n",
    "    st.session_state.messages.append({\"role\": \"assistant\", \"content\": answer})\n",
    "'''\n",
    "\n",
    "with open(\"app.py\", \"w\") as f:\n",
    "    f.write(APP_CODE)\n",
    "\n",
    "print(\"Streamlit app written to app.py\")\n",
    "print(\"Run with: streamlit run app.py\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Final Summary & Insights\n",
    "\n",
    "| Component | Technology |\n",
    "|---|---|\n",
    "| Embeddings | all-MiniLM-L6-v2 (HuggingFace) |\n",
    "| Vector Store | FAISS |\n",
    "| LLM | GPT-3.5-turbo (OpenAI) / OPT-125M (open-source fallback) |\n",
    "| Memory | ConversationBufferMemory |\n",
    "| Framework | LangChain |\n",
    "| UI | Streamlit |\n",
    "\n",
    "### Key Observations\n",
    "- RAG reduces hallucinations by grounding LLM responses in retrieved document chunks.\n",
    "- Conversation memory allows follow-up questions without re-stating context.\n",
    "- FAISS enables sub-millisecond semantic search even on CPU for small corpora.\n",
    "- The architecture scales to large corpora: simply load more documents into the vector store.\n",
    "\n",
    "### Skills Demonstrated\n",
    "- Conversational AI with context memory\n",
    "- Document embedding and semantic vector search\n",
    "- Retrieval-Augmented Generation (RAG)\n",
    "- LLM integration and Streamlit deployment"
   ]
  }
